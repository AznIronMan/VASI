# Public-safe VASI production configuration contract.
# Copy only non-secret settings into the deployment environment. Replace all
# example.test names. Mount secret files separately; never put their contents
# in this file, an image, Compose YAML, shell history, or Git.

NODE_ENV=production
VASI_CONFIG_PROFILE=production
PORT=3000

# The public URL is the edge gateway. The private URL is the protected origin.
NEXT_PUBLIC_WEBAPP_URL=https://sign.example.test
NEXT_PRIVATE_INTERNAL_WEBAPP_URL=https://origin.internal.example.test
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.test
NEXT_PUBLIC_SIGNING_CONTACT_INFO=https://www.example.test

# Files are one-value UTF-8 secrets with an optional final newline.
NEXTAUTH_SECRET_FILE=/run/secrets/vasi-session-secret
NEXT_PRIVATE_ENCRYPTION_KEY_FILE=/run/secrets/vasi-encryption-primary
NEXT_PRIVATE_ENCRYPTION_SECONDARY_KEY_FILE=/run/secrets/vasi-encryption-secondary
NEXT_PRIVATE_DATABASE_URL_FILE=/run/secrets/vasi-database-url
NEXT_PRIVATE_DIRECT_DATABASE_URL_FILE=/run/secrets/vasi-database-url

# VASI stores source and completed documents in PostgreSQL for the initial
# supported profile. Database and backup capacity must include document data.
NEXT_PUBLIC_UPLOAD_TRANSPORT=database
NEXT_PUBLIC_DOCUMENT_SIZE_UPLOAD_LIMIT=10

# Local jobs are PostgreSQL-backed and require the origin to call itself.
NEXT_PRIVATE_JOBS_PROVIDER=local

# Authenticated implicit-TLS SMTP. The delivery task must replace these fake
# values and verify sender-domain alignment before deployment.
NEXT_PRIVATE_SMTP_TRANSPORT=smtp-auth
NEXT_PRIVATE_SMTP_HOST=smtp.example.test
NEXT_PRIVATE_SMTP_PORT=465
NEXT_PRIVATE_SMTP_USERNAME_FILE=/run/secrets/vasi-smtp-username
NEXT_PRIVATE_SMTP_PASSWORD_FILE=/run/secrets/vasi-smtp-password
NEXT_PRIVATE_SMTP_SECURE=true
NEXT_PRIVATE_SMTP_UNSAFE_IGNORE_TLS=false
NEXT_PRIVATE_SMTP_FROM_NAME=VASI
NEXT_PRIVATE_SMTP_FROM_ADDRESS=signing@example.test

# The PKCS#12 file and passphrase are separate protected mounts. The production
# signing identity and timestamp policy are selected and tested in a later gate.
NEXT_PRIVATE_SIGNING_TRANSPORT=local
NEXT_PRIVATE_SIGNING_LOCAL_FILE_PATH=/run/secrets/vasi-signing.p12
NEXT_PRIVATE_SIGNING_PASSPHRASE_FILE=/run/secrets/vasi-signing-passphrase
NEXT_PRIVATE_SIGNING_TIMESTAMP_AUTHORITY=
NEXT_PRIVATE_USE_LEGACY_SIGNING_SUBFILTER=false

# VASI account creation is operator-controlled. The external edge authenticates
# staff; recipient invitation tokens continue through a separate route policy.
NEXT_PUBLIC_DISABLE_SIGNUP=true
NEXT_PUBLIC_DISABLE_EMAIL_PASSWORD_SIGNUP=true
NEXT_PUBLIC_DISABLE_GOOGLE_SIGNUP=true
NEXT_PUBLIC_DISABLE_MICROSOFT_SIGNUP=true
NEXT_PUBLIC_DISABLE_OIDC_SIGNUP=true

# Deliberately disabled Community profile features and integrations.
NEXT_PUBLIC_FEATURE_BILLING_ENABLED=false
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PRIVATE_DOCUMENSO_LICENSE_KEY=
DOCUMENSO_DISABLE_TELEMETRY=true
NEXT_PRIVATE_DOCUMENT_CONVERSION_URL=
NEXT_PRIVATE_BROWSERLESS_URL=
NEXT_PRIVATE_WEBHOOK_SSRF_BYPASS_HOSTS=
NEXT_PRIVATE_PLAIN_API_KEY=
GOOGLE_VERTEX_PROJECT_ID=
GOOGLE_VERTEX_API_KEY=
DANGEROUS_BYPASS_RATE_LIMITS=false
