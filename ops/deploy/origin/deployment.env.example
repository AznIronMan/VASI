# Public-safe Compose inputs. Copy this file outside git and replace every
# reserved example. VASI_IMAGE must be an immutable digest or unique commit tag.
VASI_IMAGE=registry.example.test/vasi@sha256:replace-me
VASI_ORIGIN_BIND_ADDRESS=192.0.2.10
VASI_ORIGIN_HTTPS_PORT=443
VASI_SERVER_NAME=origin.internal.example.test
VASI_TRUSTED_PROXY_CIDR=192.0.2.20/32
VASI_CLIENT_MAX_BODY_SIZE=12m
VASI_TLS_CERT_FILE=/etc/vasi/tls/tls.crt
VASI_TLS_KEY_FILE=/etc/vasi/tls/tls.key
VASI_SECRETS_DIR=/etc/vasi/secrets

NEXT_PUBLIC_WEBAPP_URL=https://sign.example.test
NEXT_PRIVATE_INTERNAL_WEBAPP_URL=https://origin.internal.example.test
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.test
NEXT_PUBLIC_SIGNING_CONTACT_INFO=https://www.example.test
NEXT_PUBLIC_DOCUMENT_SIZE_UPLOAD_LIMIT=10

NEXT_PRIVATE_SMTP_HOST=smtp.azurecomm.net
NEXT_PRIVATE_SMTP_PORT=587
NEXT_PRIVATE_SMTP_SECURE=false
NEXT_PRIVATE_SMTP_FROM_NAME=VASI
NEXT_PRIVATE_SMTP_FROM_ADDRESS=signing@example.test
NEXT_PRIVATE_SIGNING_TIMESTAMP_AUTHORITY=

# One-time bootstrap inputs. Remove the password file after successful use.
VASI_BOOTSTRAP_ADMIN_EMAIL=initial-admin@example.test
VASI_BOOTSTRAP_ADMIN_NAME=Initial VASI Administrator
