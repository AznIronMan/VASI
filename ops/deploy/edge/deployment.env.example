# Public-safe examples only. Copy outside Git and replace every reserved value.
VASI_EDGE_IMAGE=vasi-edge:replace-with-unique-commit
VASI_EDGE_BIND_ADDRESS=192.0.2.20
VASI_EDGE_PORT=8080
VASI_PUBLIC_ORIGIN=https://sign.example.test
VASI_PUBLIC_HOST=sign.example.test
VASI_TRUSTED_PROXY_CIDRS=192.0.2.10/32

VASI_ORIGIN_URL=https://origin.internal.example.test:443
VASI_ORIGIN_CA_FILE=/etc/vasi-edge/tls/origin-ca.pem
VASI_FORBIDDEN_COOKIE_DOMAINS=origin.internal.example.test,fallback.example.test
VASI_PDF_UPLOAD_LIMIT_MIB=10

VASI_OIDC_ISSUER_URL=https://id.example.test
VASI_OIDC_CLIENT_ID=replace-with-registered-client-id
VASI_OIDC_EMAIL_DOMAIN=example.test
VASI_OIDC_EMAIL_CLAIM=email

VASI_EDGE_SECRETS_DIR=/etc/vasi-edge/secrets
VASI_AUTH_SUBNET=172.30.20.0/24
VASI_GATEWAY_AUTH_IP=172.30.20.2
VASI_OAUTH_AUTH_IP=172.30.20.3
