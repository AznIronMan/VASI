FROM node:24-alpine AS dependencies
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --omit=dev

FROM dependencies AS engine-tools
COPY config ./config
COPY database ./database
COPY packages ./packages
COPY scripts ./scripts
COPY services ./services

FROM engine-tools AS engine-runtime
USER node
CMD ["node", "services/engine/server.mjs"]

FROM engine-tools AS engine-maintenance
RUN apk add --no-cache postgresql17-client
USER node
ENTRYPOINT ["node"]
