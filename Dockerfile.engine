FROM node:24-alpine@sha256:a0b9bf06e4e6193cf7a0f58816cc935ff8c2a908f81e6f1a95432d679c54fbfd AS dependencies
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --omit=dev

FROM dependencies AS engine-tools
COPY config ./config
COPY database ./database
COPY packages ./packages
COPY scripts ./scripts
COPY services ./services
RUN rm -rf /usr/local/lib/node_modules/npm \
    && rm -f /usr/local/bin/npm /usr/local/bin/npx

FROM engine-tools AS engine-runtime
USER node
CMD ["node", "services/engine/server.mjs"]

FROM engine-tools AS engine-maintenance
RUN apk add --no-cache postgresql17-client
USER node
ENTRYPOINT ["node"]
