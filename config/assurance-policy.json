{
  "schema": "vasi-assurance-policy/v1",
  "accessibility": {
    "routes": [
      "/",
      "/forgot-password",
      "/invite",
      "/verify"
    ],
    "tags": [
      "wcag2a",
      "wcag2aa",
      "wcag21a",
      "wcag21aa"
    ]
  },
  "backups": {
    "maximumAgeHours": 26,
    "retain": 14
  },
  "deployment": {
    "maximumStorageUsedPercent": 85,
    "minimumCertificateDays": 30,
    "minimumStorageFreeBytes": 5368709120,
    "timeoutMilliseconds": 10000
  },
  "images": {
    "failSeverities": [
      "HIGH",
      "CRITICAL"
    ],
    "runtimeContracts": [
      {
        "entrypoint": "server.js",
        "image": "vasi",
        "imageUser": "node",
        "runUser": "1000:1000"
      },
      {
        "entrypoint": "scripts/migrate.mjs",
        "image": "vasi-settings",
        "imageUser": "",
        "runUser": "1000:1000"
      },
      {
        "entrypoint": "services/engine/server.mjs",
        "image": "vasi-engine",
        "imageUser": "node",
        "runUser": "1000:1000"
      },
      {
        "entrypoint": "scripts/settings.mjs",
        "image": "vasi-engine-tools",
        "imageUser": "",
        "runUser": "0:0"
      },
      {
        "entrypoint": "scripts/backup.mjs",
        "image": "vasi-engine-maintenance",
        "imageUser": "node",
        "runUser": "1000:1000"
      }
    ],
    "scannerImage": "aquasec/trivy@sha256:cffe3f5161a47a6823fbd23d985795b3ed72a4c806da4c4df16266c02accdd6f"
  },
  "load": {
    "concurrency": 20,
    "endpoints": [
      "/api/health",
      "/api/brand"
    ],
    "maximumErrorRate": 0,
    "maximumP95Milliseconds": 1000,
    "requests": 200,
    "timeoutMilliseconds": 5000
  },
  "operations": {
    "maximumDatabaseQueryMilliseconds": 2000,
    "maximumDatabaseWaitingClients": 0,
    "maximumFailedJobs24Hours": 0,
    "maximumGatewayFailures24Hours": 0,
    "maximumOldestPendingDataRequestSeconds": 2592000,
    "maximumOldestPendingSeconds": 900,
    "maximumRetryableScans": 0,
    "maximumScanFailures24Hours": 0,
    "maximumScanThreats24Hours": 0,
    "maximumStaleRunningJobs": 0
  },
  "source": {
    "failAuditSeverities": [
      "high",
      "critical"
    ]
  }
}
