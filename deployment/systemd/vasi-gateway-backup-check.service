[Unit]
Description=Verify VASI gateway matched backup freshness
Documentation=file:/opt/vasi/current/docs/architecture/backup-continuity.md
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target
OnFailure=vasi-gateway-alert-record@%n.service

[Service]
Type=oneshot
User=root
Group=root
UMask=0077
WorkingDirectory=/opt/vasi/current
ExecStart=/usr/bin/docker compose -f compose.production.yaml --profile tools run --rm -T --no-deps -v /var/lib/vasi/backups/maintenance/scheduled:/backup:ro maintenance scripts/backup-continuity.mjs check /backup
TimeoutStartSec=30min
Nice=10
IOSchedulingClass=idle
CapabilityBoundingSet=CAP_DAC_OVERRIDE CAP_DAC_READ_SEARCH
LockPersonality=yes
MemoryDenyWriteExecute=yes
NoNewPrivileges=yes
PrivateDevices=yes
PrivateTmp=yes
ProtectControlGroups=yes
ProtectHome=yes
ProtectKernelModules=yes
ProtectKernelTunables=yes
ProtectSystem=strict
RestrictAddressFamilies=AF_UNIX
RestrictSUIDSGID=yes
SystemCallArchitectures=native
