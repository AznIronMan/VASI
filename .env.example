# Public origin and session encryption (generate with: openssl rand -base64 48)
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters

# Internal administration origin and authorized operator emails
VASI_ADMIN_ORIGIN=http://localhost:3000
VASI_ADMIN_EMAILS=admin@example.com

# PostgreSQL
DATABASE_URL=postgresql://vasi:vasi@localhost:5432/vasi
DATABASE_SSL=disable
DATABASE_POOL_MAX=10

# Social providers (a provider is enabled only when its complete pair is set)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=

# Optional Apple client-secret generation. Use these instead of APPLE_CLIENT_SECRET.
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Transactional email for verification and password recovery
# Graph is preferred for Microsoft 365; use smtp to select the fallback below.
AUTH_EMAIL_PROVIDER=graph
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER_EMAIL=

# SMTP fallback
AUTH_EMAIL_FROM="V·Sign <no-reply@cnb.llc>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
