{
  "name": "vasi",
  "version": "0.4.0",
  "private": true,
  "description": "Verified Authorized Signing Infrastructure",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm run test",
    "auth:migrate": "node scripts/migrate.mjs",
    "db:migrate": "node scripts/migrate.mjs",
    "engine:migrate": "node scripts/engine-migrate.mjs",
    "engine:probe": "node scripts/probe-engine.mjs",
    "settings": "node scripts/settings.mjs",
    "settings:init": "node scripts/settings.mjs init",
    "settings:list": "node scripts/settings.mjs list"
  },
  "dependencies": {
    "better-auth": "1.6.23",
    "jose": "6.2.3",
    "next": "16.2.10",
    "nodemailer": "9.0.3",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/nodemailer": "8.0.1",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "postcss": "8.5.18"
  }
}
